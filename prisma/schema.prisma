generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(uuid())
  email        String
  name         String
  projectUsers ProjectUser[]
}

model Project {
  id           String        @id @default(uuid())
  name         String
  clientId     String        @unique
  clientSecret String
  projectUsers ProjectUser[]
  routes       Route[]
}

model Route {
  id          String       @id @default(uuid())
  path        String
  method      Method
  projectId   String
  permissions Permission[]
  project     Project      @relation(fields: [projectId], references: [id])

  @@unique([path, method, projectId])
  @@index([projectId])
}

model Role {
  id           String        @id @default(uuid())
  name         RoleEnum
  projectId    String
  permissions  Permission[]
  projectUsers ProjectUser[]
}

model Permission {
  id      String @id @default(uuid())
  roleId  String
  routeId String
  role    Role   @relation(fields: [roleId], references: [id])
  route   Route  @relation(fields: [routeId], references: [id])

  @@unique([roleId, routeId])
  @@index([roleId, routeId])
}

model ProjectUser {
  userId    String
  projectId String
  roleId    String
  project   Project @relation(fields: [projectId], references: [id])
  role      Role    @relation(fields: [roleId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@id([userId, projectId])
  @@index([projectId, roleId])
}

enum RoleEnum {
  ADMIN
  MANAGER
  VIEWER
}

enum Method {
  GET
  POST
  DELETE
  UPDATE
  PUT
  PATCH
}
